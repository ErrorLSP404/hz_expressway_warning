<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="net.huizhu.core.dao.SysRoleDao">

    <!-- 查询用户所有角色 -->
    <select id="selectSysRoleByUserId" parameterType="long" resultType="SysRole">
        SELECT r.id,r.role_name FROM sys_role r LEFT JOIN sys_user_role u ON u.role_id = r.id WHERE u.user_id = #{userid}
    </select>


</mapper>